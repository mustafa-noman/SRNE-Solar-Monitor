<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SolarPowerMonitor.Mobile"
             x:Class="SolarPowerMonitor.Mobile.MainPage"
             BackgroundColor="{StaticResource PageBackground}"
             Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,28" Spacing="18">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <Border WidthRequest="64" HeightRequest="64" BackgroundColor="{StaticResource SolarAccent}" StrokeThickness="0" StrokeShape="RoundRectangle 18">
                    <Label Text="☀" TextColor="#091727" FontSize="35" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="Solar Monitor" FontSize="26" FontFamily="OpenSansSemibold" SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Home Solar" FontSize="15" TextColor="{StaticResource SecondaryText}" />
                    <HorizontalStackLayout Spacing="7">
                        <Label Text="●" TextColor="{Binding StatusColor}" FontSize="16" />
                        <Label Text="{Binding StatusText}" TextColor="{Binding StatusColor}" FontSize="16" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                <Button Grid.Column="2" Text="↻" FontSize="24" WidthRequest="56" HeightRequest="56" CornerRadius="18" BackgroundColor="#142942" TextColor="White" Command="{Binding RefreshCommand}" SemanticProperties.Description="Refresh telemetry" />
            </Grid>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="18">
                    <Label Text="SOLAR GENERATION" TextColor="{StaticResource SolarAccent}" FontFamily="OpenSansSemibold" SemanticProperties.HeadingLevel="Level2" />
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="{Binding SolarPower}" FontSize="64" FontFamily="OpenSansSemibold" />
                        <Label Text="W" FontSize="29" TextColor="{StaticResource SecondaryText}" VerticalOptions="End" Margin="0,0,0,9" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding SolarStatusText}" TextColor="{StaticResource SecondaryText}" FontSize="15" />
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Recent solar output" FontFamily="OpenSansSemibold" />
                        <Label Text="Latest session readings" TextColor="{StaticResource SecondaryText}" FontSize="12" />
                    </VerticalStackLayout>
                    <local:HistoryGraphView HeightRequest="96" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                        <VerticalStackLayout>
                            <Label Text="PV VOLTAGE" TextColor="{StaticResource SecondaryText}" FontSize="12" />
                            <Label Text="{Binding PvVoltageText}" FontSize="25" FontFamily="OpenSansSemibold" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="PV CURRENT" TextColor="{StaticResource SecondaryText}" FontSize="12" />
                            <Label Text="{Binding PvCurrentText}" FontSize="25" FontFamily="OpenSansSemibold" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="18">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="BATTERY" TextColor="{StaticResource BatteryAccent}" FontFamily="OpenSansSemibold" SemanticProperties.HeadingLevel="Level2" />
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="{Binding BatteryPercent}" FontSize="52" FontFamily="OpenSansSemibold" TextColor="{StaticResource BatteryAccent}" />
                                <Label Text="%" FontSize="25" TextColor="{StaticResource SecondaryText}" VerticalOptions="End" Margin="0,0,0,7" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding BatteryStatusText}" TextColor="{StaticResource SecondaryText}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" WidthRequest="82" HeightRequest="82" Stroke="{StaticResource BatteryAccent}" StrokeThickness="8" StrokeShape="RoundRectangle 41" VerticalOptions="Center">
                            <Label Text="ϟ" TextColor="{StaticResource BatteryAccent}" FontSize="39" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource CardBorder}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                        <VerticalStackLayout>
                            <Label Text="BATTERY VOLTAGE" TextColor="{StaticResource SecondaryText}" FontSize="12" />
                            <Label Text="{Binding BatteryVoltageText}" FontSize="24" FontFamily="OpenSansSemibold" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="CHARGE CURRENT" TextColor="{StaticResource SecondaryText}" FontSize="12" />
                            <Label Text="{Binding ChargeCurrentText}" FontSize="24" FontFamily="OpenSansSemibold" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="DEVICE" TextColor="#67B7FF" FontSize="12" />
                        <Label Text="{Binding DeviceName}" FontSize="23" FontFamily="OpenSansSemibold" />
                        <Label Text="{Binding DataSourceText}" TextColor="{StaticResource SecondaryText}" FontSize="13" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                        <Label Text="LAST UPDATE" TextColor="{StaticResource SecondaryText}" FontSize="12" HorizontalTextAlignment="End" />
                        <Label Text="{Binding LastUpdateText}" FontSize="21" HorizontalTextAlignment="End" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
            <Label Text="{Binding ErrorMessage}" TextColor="#FF7B7B" FontSize="13" IsVisible="{Binding HasError}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
