<Window x:Class="SolarPowerMonitor.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Solar Power Widget"
        Width="360"
        Height="190"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Border Background="#F207111F"
            BorderBrush="#3347A7FF"
            BorderThickness="1"
            CornerRadius="22"
            Padding="20"
            MouseLeftButtonDown="Widget_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="5"
                              Opacity="0.45"
                              Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="30"
                            Height="30"
                            Background="#FFFFB547"
                            CornerRadius="10">
                        <TextBlock Text="☀"
                                   Foreground="#07111F"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="HOME SOLAR"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#8FA4BC"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot"
                                     Width="7"
                                     Height="7"
                                     Fill="#FFB547"
                                     Margin="0,0,6,0"/>
                            <TextBlock x:Name="StatusText"
                                       Text="CONNECTING"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#FFB547"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="↗"
                            ToolTip="Open full dashboard"
                            Click="OpenDashboard_Click"
                            Style="{StaticResource IconButton}"
                            Width="32"
                            Height="32"
                            FontSize="15"
                            Margin="0,0,8,0"/>
                    <Button Content="×"
                            ToolTip="Close widget"
                            Click="Close_Click"
                            Style="{StaticResource IconButton}"
                            Width="32"
                            Height="32"
                            FontSize="17"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,14,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="SOLAR OUTPUT"
                               FontSize="10"
                               Foreground="#8FA4BC"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SolarPowerText"
                                   Text="--"
                                   FontSize="36"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text=" W"
                                   FontSize="17"
                                   Foreground="#8FA4BC"
                                   VerticalAlignment="Bottom"
                                   Margin="1,0,0,6"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="#263C54"/>

                <StackPanel Grid.Column="2"
                            Margin="20,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="BATTERY"
                               FontSize="10"
                               Foreground="#8FA4BC"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="BatterySocText"
                                   Text="--"
                                   FontSize="36"
                                   FontWeight="SemiBold"
                                   Foreground="#35D49A"/>
                        <TextBlock Text="%"
                                   FontSize="17"
                                   Foreground="#8FA4BC"
                                   VerticalAlignment="Bottom"
                                   Margin="2,0,0,6"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <TextBlock x:Name="DetailsText"
                           Text="Waiting for SRNE telemetry…"
                           FontSize="11"
                           Foreground="#8FA4BC"/>
                <TextBlock x:Name="LastUpdateText"
                           Text="--:--"
                           HorizontalAlignment="Right"
                           FontSize="11"
                           Foreground="#8FA4BC"/>
            </Grid>
        </Grid>
    </Border>
</Window>
